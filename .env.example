# ─── Base URLs ───────────────────────────────────────
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (MongoDB) ─────────────────────────────
DATABASE_URL=

# ─── NextAuth ────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─── Google OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (SMTP) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hema Sarees <noreply@hemasaree.com>"

# ─── Redis (Optional — app works without it) ────────
# Required for: Bull email queue, rate limiting, caching
# On Vercel: leave blank for in-memory fallbacks
REDIS_URL=redis://localhost:6379

# ─── Feature Flags ──────────────────────────────────
# Set to "true" only in Docker/self-hosted (not on Vercel)
ENABLE_CRON=false

# ─── Sanity CMS (Optional) ──────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
