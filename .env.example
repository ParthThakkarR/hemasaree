# ─── Base URLs ───────────────────────────────────────
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (MongoDB) ─────────────────────────────
DATABASE_URL=

# ─── NextAuth ────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_DEBUG=false

# ─── Google OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (SMTP) ───────────────────────────────────
# Use EMAIL_SERVER_* naming convention (preferred)
# EMAIL_HOST/EMAIL_PORT/EMAIL_USER/EMAIL_PASS also supported for backwards compatibility
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Hema Sarees <noreply@hemasaree.com>"

# Legacy email config (fallback)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_SECURE=
EMAIL_DOMAIN=

# ─── Redis (Optional — app works without it) ────────
# Required for: Bull email queue, rate limiting, caching
# On Vercel: leave blank for in-memory fallbacks
REDIS_URL=redis://localhost:6379

# ─── Feature Flags ──────────────────────────────────
# Set to "true" only in Docker/self-hosted (not on Vercel)
ENABLE_CRON=false

# ─── Sanity CMS (Optional) ──────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Deployment ─────────────────────────────────────
VERCEL_URL=
NEXT_OUTPUT_STANDALONE=
