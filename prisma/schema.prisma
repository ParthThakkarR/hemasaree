generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// This enum now covers the full lifecycle of an item
enum OrderItemStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id                   String     @id @default(auto()) @map("_id") @db.ObjectId
  name                 String?    
  firstName            String?    
  lastName             String?
  addresses            Address[]
  email                String     @unique
  emailVerified        DateTime?
  image                String?
  phone                String?
  isAdmin              Boolean    @default(false)
  password             String?    
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  passwordResetToken   String?
  passwordResetExpires DateTime?
  products             Product[]  @relation("UserProducts")
  orders               Order[]
  payments             Payment[]
  carts                Cart[]
  wishlist             WishlistItem[]
  reviews              Review[]
  accounts             Account[]
  sessions             Session[]

  @@index([createdAt])
}

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventName String
  url       String?
  userId    String?  @db.ObjectId
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt, eventName])
}

model Address {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String   @db.ObjectId
  user                  User     @relation(fields: [userId], references: [id])
  fullName              String
  mobileNumber          String
  alternateMobileNumber String?
  houseNumber           String
  buildingName          String?
  area                  String
  landmark              String?
  city                  String
  district              String?
  state                 String
  pincode               String
  addressType           String
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

model StoreSettings {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  deliveryChargeGujarat Float    @default(80)
  deliveryChargeDefault Float    @default(150)
  polishPrice           Float    @default(450)
  isPolishEnabled       Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
   id           String      @id @default(auto()) @map("_id") @db.ObjectId
   name         String
   description  String?
   color        String
   fabric       String?
    occasion     String
   price        Float
   mrp          Float?
   stock        Int
   images       String[] 
   categoryId   String      @db.ObjectId
   category     Category    @relation(fields: [categoryId], references: [id])
   userId       String      @db.ObjectId
   user         User        @relation("UserProducts", fields: [userId], references: [id])
   createdAt    DateTime    @default(now())
   updatedAt    DateTime    @updatedAt
   isDeleted    Boolean     @default(false)
   deletedAt    DateTime?
   cartItems    CartItem[]
   orderItems   OrderItem[]
   wishlistItems WishlistItem[]
   reviews      Review[]

   @@index([categoryId])
   @@index([name])
   @@index([createdAt])
   @@index([price])
   @@index([occasion])
   @@index([color])
   @@index([isDeleted, categoryId])
   @@index([isDeleted, createdAt])
 }

model Cart {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  userId     String     @db.ObjectId
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]
  totalPrice Float      @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
}

model CartItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId       String   @db.ObjectId
  cart         Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId    String   @db.ObjectId
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productName  String
  productImage String?
  quantity     Int      @default(1)
  price        Float
  withPolish   Boolean  @default(false)
  createdAt    DateTime @default(now()) 

  @@index([cartId])
  @@index([productId])
}

model Order {
   id              String      @id @default(auto()) @map("_id") @db.ObjectId
   userId          String?     @db.ObjectId
   user            User?       @relation(fields: [userId], references: [id])
   orderItems      OrderItem[]
   totalAmount     Float
   deliveryCharge  Float       @default(0)
   discountAmount  Float       @default(0)
   offerCode       String?
   status          OrderStatus @default(PENDING)
   createdAt       DateTime    @default(now())
   updatedAt       DateTime    @updatedAt
   payment         Payment?
   shippingAddress String?
   cancelledAt  DateTime?

   @@index([userId])
   @@index([status])
   @@index([createdAt])
   @@index([userId, status])
   @@index([createdAt, status])
 }

model OrderItem {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String          @db.ObjectId
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?         @db.ObjectId
  product        Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  withPolish     Boolean         @default(false)
  status         OrderItemStatus @default(PENDING)
  productName    String
  productImage   String?
  quantity       Int
  price          Float

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  orderId   String   @db.ObjectId @unique
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Float
  method    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Newsletter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}

model EmailLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  subject   String
  type      String   
  status    String   
  error     String?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating     Int      // 1-5
  title      String?
  text       String
  images     String[] // Customer uploaded photos
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
  @@index([isApproved])
}

model Offer {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  title       String
  description String?
  type        String      // "flat" | "percentage"
  value       Float
  minOrder    Float     @default(0)
  maxDiscount Float?
  usageLimit  Int?
  usageCount  Int       @default(0)
  perUser     Int       @default(1)
  isActive    Boolean   @default(true)
  startsAt    DateTime  @default(now())
  expiresAt   DateTime?
  categoryId  String?   @db.ObjectId
  isFirstOrderOnly Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, startsAt, expiresAt])
}
